# ─── App ───────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── MongoDB ───────────────────────────────────────────
MONGODB_URI=your_mongodb_connection_string_here
MONGODB_DB_NAME=sass_db

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── OpenAI ────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─── Inter-service HTTP URLs (replaces Kafka) ───────────
ALERT_SERVICE_URL=http://localhost:3003
EVENT_SERVICE_URL=http://localhost:3002

# ─── Service Ports ─────────────────────────────────────
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
EVENT_SERVICE_PORT=3002
ALERT_SERVICE_PORT=3003
GENAI_SERVICE_PORT=3004
LOG_SERVICE_PORT=3005
DETECTION_SERVICE_PORT=8001
FRONTEND_PORT=3006

# ─── Service URLs (for inter-service calls) ────────────
AUTH_SERVICE_URL=http://auth-service:3001
EVENT_SERVICE_URL=http://event-service:3002
ALERT_SERVICE_URL=http://alert-service:3003
GENAI_SERVICE_URL=http://genai-service:3004
DETECTION_SERVICE_URL=http://detection-service:8001

# ─── CORS ──────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3006,http://localhost:3000

# ─── Detection ─────────────────────────────────────────
CAMERA_INDEX=0
YOLO_MODEL=yolov8n.pt
CONFIDENCE_THRESHOLD=0.45
LOITERING_THRESHOLD_SECONDS=30
ZONE_COORDINATES=[]

# ─── Alert ─────────────────────────────────────────────
ALERT_RATE_LIMIT_SECONDS=10
MAX_ALERT_HISTORY=100

# ─── GenAI ─────────────────────────────────────────────
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.3
MAX_EVENTS_TO_CONTEXT=50
